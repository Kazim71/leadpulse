# Copy to .env and fill in. Never commit .env.

# Supabase project URL, e.g. https://abcdefghijkl.supabase.co
SUPABASE_URL=

# SERVICE ROLE key — Dashboard -> Project Settings -> API -> service_role.
# This bypasses RLS entirely. Server-side only; it must never reach a
# browser, the tracking snippet, or a client bundle.
SUPABASE_SERVICE_ROLE_KEY=

PORT=4000

# Optional (defaults shown)
NODE_ENV=development
LOG_LEVEL=info

# resolveOrg api_key cache lifetime, seconds
ORG_CACHE_TTL_SECONDS=60

# Rate limit: max events per visitor_id per org per window
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated allowed origins for CORS, or * for any.
# Tracking snippets run on arbitrary client domains, so * is the practical
# default until per-org origin allowlists land (phase 4).
CORS_ORIGINS=*
