# Browser-exposed. These two are SAFE to ship to the client: the anon key is
# designed to be public and every read it performs is constrained by RLS.
# The service_role key must NEVER appear in this file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. No NEXT_PUBLIC_ prefix, so Next.js will not inline it into the
# client bundle. Used exclusively by the platform-admin provisioning Route
# Handlers (creating auth users and bootstrapping tenants) — never for reads.
SUPABASE_SERVICE_ROLE_KEY=
